#!/bin/bash
# Universal llama.cpp server launcher for distrobox containers.
# Always runs llama-server in router mode against an INI preset file.
# Single-model configs are just one-section INIs; multi-model configs
# (e.g. router.ini) hold multiple sections in one file.

set -e

# Config directory — supports LLAMA_CONFIG_DIR override.
CONFIG_DIR="${LLAMA_CONFIG_DIR:=${XDG_CONFIG_HOME:=$HOME/.config}/llama-cpp}"
PRESET_NAME="${1:-}"

if [[ -z "$PRESET_NAME" ]]; then
    echo "Usage: llama-server-container <preset-name> [extra llama-server args]"
    echo ""
    echo "Available presets in $CONFIG_DIR:"
    ls -1 "$CONFIG_DIR"/*.ini 2>/dev/null | xargs -n1 basename -s .ini || echo "  (none)"
    exit 1
fi
shift

PRESET_FILE="$CONFIG_DIR/${PRESET_NAME}.ini"
if [[ ! -f "$PRESET_FILE" ]]; then
    echo "Error: Preset file not found: $PRESET_FILE"
    echo "Available presets:"
    ls -1 "$CONFIG_DIR"/*.ini 2>/dev/null | xargs -n1 basename -s .ini || echo "  (none)"
    exit 1
fi

# Substitute MODELS_DIR into a resolved copy of the preset so the ini files
# stay path-agnostic in the repo. Set MODELS_DIR before launching, e.g.:
#   export MODELS_DIR=~/models
# Defaults to ~/models if unset.
# The resolved file keeps the same name so ExecStop pkill patterns still match.
MODELS_DIR="${MODELS_DIR:-$HOME/models}"
RESOLVED_DIR="${XDG_RUNTIME_DIR:-/tmp}/llama-resolved"
mkdir -p "$RESOLVED_DIR"
PRESET_FILE_RESOLVED="$RESOLVED_DIR/${PRESET_NAME}.ini"
sed "s|/path/to/models|${MODELS_DIR}|g" "$PRESET_FILE" > "$PRESET_FILE_RESOLVED"

# ROCm env vars for Strix Halo unified memory.
# Note: do NOT set HSA_OVERRIDE_GFX_VERSION — kyuz0 images compile natively for gfx1151.
if [[ -d /opt/rocm ]]; then
    export GGML_CUDA_ENABLE_UNIFIED_MEMORY="${GGML_CUDA_ENABLE_UNIFIED_MEMORY:-1}"
    export GPU_MAX_HW_QUEUES="${GPU_MAX_HW_QUEUES:-2}"
    export LLAMA_SET_ROWS="${LLAMA_SET_ROWS:-1}"
fi

LLAMA_CMD=(
    llama-server
    --models-preset "$PRESET_FILE_RESOLVED"
    --no-models-autoload
    "$@"
)

echo "Starting llama.cpp router with preset: $PRESET_NAME"
echo "Preset file: $PRESET_FILE (MODELS_DIR=$MODELS_DIR)"
echo "Command: ${LLAMA_CMD[*]}"
echo ""

exec "${LLAMA_CMD[@]}"
