#!/bin/bash
# Host-side launcher for ComfyUI image generation server.
# Uses a dedicated distrobox container with ROCm PyTorch.
#
# Usage: comfyui-server [config-name] [extra args]
#   comfyui-server flux-schnell
#   comfyui-server flux-schnell --port 8082
#
# If no config name is given, lists available presets and exits.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_DIR="${LLAMA_CONFIG_DIR:=$SCRIPT_DIR/configs}"
CONTAINER_NAME="${COMFYUI_CONTAINER:-comfyui-rocm}"
IMAGE="${COMFYUI_IMAGE:-docker.io/rocm/pytorch:rocm7.2.2_ubuntu24.04_py3.12_pytorch_release_2.10.0}"

MODEL_CONFIG="${1:-}"

if [[ -z "$MODEL_CONFIG" ]]; then
    echo "Usage: comfyui-server <config-name> [extra args]"
    echo ""
    echo "Available presets in $CONFIG_DIR/comfyui/workflows/:"
    ls -1 "$CONFIG_DIR"/comfyui/workflows/*.json 2>/dev/null | while read -r json; do
        preset_name=$(basename "$json" .json)
        echo "  - $preset_name"
    done
    exit 0
fi

shift

WORKFLOW_FILE="$CONFIG_DIR/comfyui/workflows/${MODEL_CONFIG}.json"
if [[ ! -f "$WORKFLOW_FILE" ]]; then
    echo "Error: Workflow preset not found: $WORKFLOW_FILE"
    echo "Available presets:"
    ls -1 "$CONFIG_DIR"/comfyui/workflows/*.json 2>/dev/null | xargs -n1 basename -s .json
    exit 1
fi

# Check if container exists, if not create it
if ! distrobox list | grep -q "| $CONTAINER_NAME"; then
    echo "Container $CONTAINER_NAME not found. Creating with $IMAGE..."
    distrobox create -n "$CONTAINER_NAME" \
        --image "$IMAGE" \
        --additional-flags "--device /dev/kfd --device /dev/dri --security-opt seccomp=unconfined"
    
    echo "Container created. Run ./scripts/setup-comfyui-container.sh to install ComfyUI inside it."
    exit 1
fi

# Sync workflow presets into container
for json in "$CONFIG_DIR"/comfyui/workflows/*.json; do
    [[ -f "$json" ]] || continue
    cat "$json" | distrobox enter "$CONTAINER_NAME" -- bash -c "mkdir -p ~/.config/comfyui/workflows && cat > ~/.config/comfyui/workflows/$(basename "$json")" 2>/dev/null || true
done

# Sync extra_model_paths.yaml so ComfyUI reads the central model store directly.
# Substitute the /path/to/models placeholder with $MODELS_DIR (same convention as
# the llama-server presets) so the repo file stays path-agnostic.
MODELS_DIR="${MODELS_DIR:-$HOME/models}"
EXTRA_PATHS_FILE="$CONFIG_DIR/comfyui/extra_model_paths.yaml"
if [[ -f "$EXTRA_PATHS_FILE" ]]; then
    sed "s|/path/to/models|${MODELS_DIR}|g" "$EXTRA_PATHS_FILE" \
        | distrobox enter "$CONTAINER_NAME" -- bash -c "mkdir -p ~/.config/comfyui && cat > ~/.config/comfyui/extra_model_paths.yaml" 2>/dev/null || true
fi

# Sync container wrapper into container
CONTAINER_WRAPPER="$SCRIPT_DIR/comfyui-server-container"
if [[ -f "$CONTAINER_WRAPPER" ]]; then
    cat "$CONTAINER_WRAPPER" | distrobox enter "$CONTAINER_NAME" -- bash -c "mkdir -p ~/.local/bin && cat > ~/.local/bin/comfyui-server-container && chmod +x ~/.local/bin/comfyui-server-container" 2>/dev/null || true
fi

# Sync bridge script into container
BRIDGE_SCRIPT="$SCRIPT_DIR/comfyui-bridge/bridge.py"
if [[ -f "$BRIDGE_SCRIPT" ]]; then
    cat "$BRIDGE_SCRIPT" | distrobox enter "$CONTAINER_NAME" -- bash -c "mkdir -p ~/.local/bin && cat > ~/.local/bin/comfyui-bridge.py && chmod +x ~/.local/bin/comfyui-bridge.py" 2>/dev/null || true
fi

# Launch server via container wrapper
distrobox enter "$CONTAINER_NAME" -- "\$HOME/.local/bin/comfyui-server-container" "$MODEL_CONFIG" "$@"
